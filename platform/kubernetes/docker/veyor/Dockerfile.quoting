# Veyor Go Quoting Service — Multi-stage Dockerfile
FROM golang:1.21-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /quoting-service cmd/server/main.go

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=builder /quoting-service /quoting-service
USER nonroot:nonroot
EXPOSE 50051
ENTRYPOINT ["/quoting-service"]
