# ==============================================================================
# Platform Engineering Layer — Environment Secrets Template
# ==============================================================================

# --- GitHub Integration ---
# Required for Backstage, Argo CD, and GitHub Actions
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxx

# --- Langsmith Tracing ---
# Required for AI agent observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=developer-portal-agents
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- AWS Infrastructure (Free Tier) ---
# Required for Terraform and Crossplane
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1

# --- Feature Flags ---
# Flagsmith API Key
FLAGSMITH_ENVIRONMENT_KEY=ser.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Observability ---
# Grafana admin password (default: admin)
GRAFANA_ADMIN_PASSWORD=admin
