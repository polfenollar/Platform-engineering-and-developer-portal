    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "@playwright/test": "^1.42.0"
    {%- if styling == 'tailwind' %},
    "tailwindcss": "^3.4.1",
    "postcss": "^8",
    "autoprefixer": "^10.4.17"
    {%- endif %}
  }
